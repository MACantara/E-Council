# Copy this file to .env and fill in the values for your environment.
# .env is loaded automatically by python-dotenv and should never be committed.

# -----------------------------------------------------------------------------
# Flask Core
# -----------------------------------------------------------------------------
# Set to 'development' or 'production' as needed. CI uses 'testing' implicitly.
FLASK_ENV=development

# Used for sessions, CSRF tokens, and URLSafeTimedSerializer.
# Generate a strong random key, e.g. with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="your-secret-key-here"

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Example for local MySQL (pymysql must be installed):
# SQLALCHEMY_DATABASE_URI="mysql+pymysql://user:password@localhost/e_council"
# Example for local SQLite:
SQLALCHEMY_DATABASE_URI="sqlite:///e_council.db"

# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------
# Supported providers: smtp, console, memory, sendgrid, mailgun, null
EMAIL_PROVIDER=smtp

# For Gmail, use an App Password and enable TLS on port 587.
MAIL_SERVER="smtp.gmail.com"
MAIL_PORT="587"
MAIL_USE_TLS="True"
MAIL_USE_SSL="False"
MAIL_USERNAME="your-email@example.com"
MAIL_PASSWORD="your-email-app-password"
MAIL_DEFAULT_SENDER="no-reply@example.com"

# SendGrid (only required when EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY="your-sendgrid-api-key"
SENDGRID_FROM_EMAIL="no-reply@example.com"

# Mailgun (only required when EMAIL_PROVIDER=mailgun)
MAILGUN_API_KEY="your-mailgun-api-key"
MAILGUN_DOMAIN="your-mailgun-domain"
MAILGUN_FROM_EMAIL="no-reply@example.com"

# -----------------------------------------------------------------------------
# Storage (uploads for profiles, signatures, receipts, and documentation)
# -----------------------------------------------------------------------------
# Supported providers: cloudinary, local, memory, null
# When using 'local', files are stored under STORAGE_LOCAL_PATH and served from
# STORAGE_LOCAL_BASE_URL.
STORAGE_PROVIDER=cloudinary
STORAGE_LOCAL_PATH=uploads
STORAGE_LOCAL_BASE_URL=/static/uploads

# -----------------------------------------------------------------------------
# Cloudinary (only required when STORAGE_PROVIDER=cloudinary)
# -----------------------------------------------------------------------------
# Get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# -----------------------------------------------------------------------------
# AI
# -----------------------------------------------------------------------------
# Supported providers: gemini, openai, anthropic, local, mock
AI_PROVIDER=gemini

# Google Gemini (only required when AI_PROVIDER=gemini)
GOOGLE_GEMINI_AI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-1.5-flash"

# OpenAI (only required when AI_PROVIDER=openai)
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL="gpt-4o-mini"

# Anthropic (only required when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY="your-anthropic-api-key"
ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"

# Local / Ollama (only required when AI_PROVIDER=local)
LOCAL_AI_BASE_URL="http://localhost:11434/v1"
LOCAL_AI_MODEL="llama3"

# -----------------------------------------------------------------------------
# FastAPI (optional; defaults are provided in api/settings.py)
# -----------------------------------------------------------------------------
# FASTAPI_DATABASE_URI="sqlite:///fastapi.db"
# API_BASE_URL="http://localhost:8000"
# FRONTEND_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Optional: Sentry error tracking
# -----------------------------------------------------------------------------
# Leave blank to disable. Get a DSN from https://sentry.io/
SENTRY_DSN=""
