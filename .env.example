# Copy this file to .env and fill in the values for your environment.
# .env is loaded automatically by python-dotenv and should never be committed.

# -----------------------------------------------------------------------------
# Flask Core
# -----------------------------------------------------------------------------
# Set to 'development' or 'production' as needed. CI uses 'testing' implicitly.
FLASK_ENV=development

# Used for sessions, CSRF tokens, and URLSafeTimedSerializer.
# Generate a strong random key, e.g. with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="your-secret-key-here"

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Example for local MySQL (pymysql must be installed):
# SQLALCHEMY_DATABASE_URI="mysql+pymysql://user:password@localhost/e_council"
# Example for local SQLite:
SQLALCHEMY_DATABASE_URI="sqlite:///e_council.db"

# -----------------------------------------------------------------------------
# Email (SMTP)
# -----------------------------------------------------------------------------
# For Gmail, use an App Password and enable TLS on port 587.
MAIL_SERVER="smtp.gmail.com"
MAIL_PORT="587"
MAIL_USE_TLS="True"
MAIL_USE_SSL="False"
MAIL_USERNAME="your-email@example.com"
MAIL_PASSWORD="your-email-app-password"
MAIL_DEFAULT_SENDER="no-reply@example.com"

# -----------------------------------------------------------------------------
# Storage (uploads for profiles, signatures, receipts, and documentation)
# -----------------------------------------------------------------------------
# Supported providers: cloudinary, local, memory, null
# When using 'local', files are stored under STORAGE_LOCAL_PATH and served from
# STORAGE_LOCAL_BASE_URL.
STORAGE_PROVIDER=cloudinary
STORAGE_LOCAL_PATH=uploads
STORAGE_LOCAL_BASE_URL=/static/uploads

# -----------------------------------------------------------------------------
# Cloudinary (only required when STORAGE_PROVIDER=cloudinary)
# -----------------------------------------------------------------------------
# Get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# -----------------------------------------------------------------------------
# AI (Google Gemini)
# -----------------------------------------------------------------------------
# Get a key from https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_AI_API_KEY="your-gemini-api-key"

# -----------------------------------------------------------------------------
# Optional: Sentry error tracking
# -----------------------------------------------------------------------------
# Leave blank to disable. Get a DSN from https://sentry.io/
SENTRY_DSN=""
